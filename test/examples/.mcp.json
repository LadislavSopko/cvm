{
  "mcpServers": {
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-lens",
        "mongodb://root:example@localhost:27017/cvm?authSource=admin"
      ]
    },
    "cvm": {
      "command": "npx",
      "args": ["-y", "--registry", "https://registry.npmjs.org/", "cvm-server@next"],
      "env": {
        "CVM_STORAGE_TYPE": "file",
        "CVM_DATA_DIR": ".cvm",
        "CVM_LOG_LEVEL": "info",
        "CVM_SANDBOX_ROOT": "/home/laco/cvm/test/examples"
      }
    }
  }
}
