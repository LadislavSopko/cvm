{
  "mcpServers": {
    "lsai": {
      "command": "/home/laco/.lsai/run",
      "args": ["--stdio"]
    },
    "xmp4": {
      "type": "http",
      "url": "https://mcp.example4.ai/mcp"
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-lens",
        "mongodb://root:example@localhost:27017/cvm?authSource=admin"
      ]
    },
    "cvm": {
     "command": "npx",
      "args": ["-y", "cvm-server@latest"],
      "env": {
        "CVM_STORAGE_TYPE": "file",
        "CVM_DATA_DIR": ".cvm",
        "CVM_LOG_LEVEL": "info",
        "CVM_SANDBOX_PATHS":"/home/laco/cvm",
        "CVM_LOG_FILE":".cvm/cvm-debug.log"
      }
    }
  }
}
